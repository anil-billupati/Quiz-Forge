# ContestForge backend — copy to .env for local dev
CF_ENVIRONMENT=dev
CF_LOG_LEVEL=INFO
CF_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/contestforge
CF_REDIS_URL=redis://localhost:6379/0
CF_JWT_SECRET=change-me-in-env
CF_ACCESS_TOKEN_TTL_SECONDS=900
CF_REFRESH_TOKEN_TTL_SECONDS=1209600
